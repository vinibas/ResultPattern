{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet",
            "args": ["build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pack-local-ResultPattern",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "pack",
                "${workspaceFolder}/src/ViniBas.ResultPattern/ViniBas.ResultPattern.csproj",
                "-o", "${workspaceFolder}/nupkgs"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pack-local-ResultPattern.AspNet",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "pack",
                "${workspaceFolder}/src/ViniBas.ResultPattern.AspNet/ViniBas.ResultPattern.AspNet.csproj",
                "-p:UsePackageReference=true",
                "-o", "${workspaceFolder}/nupkgs"
            ],
            "dependsOn": ["pack-local-ResultPattern"],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pack-local-all",
            "dependsOn": ["pack-local-ResultPattern.AspNet"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "pack-release-ResultPattern",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "pack",
                "${workspaceFolder}/src/ViniBas.ResultPattern/ViniBas.ResultPattern.csproj",
                "-c", "Release",
                "-o", "${workspaceFolder}/nupkgs"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pack-release-ResultPattern.AspNet",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "pack",
                "${workspaceFolder}/src/ViniBas.ResultPattern.AspNet/ViniBas.ResultPattern.AspNet.csproj",
                "-p:UsePackageReference=true",
                "-c", "Release",
                "-o", "${workspaceFolder}/nupkgs"
            ],
            "dependsOn": ["pack-release-ResultPattern"],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "pack-release-all",
            "dependsOn": ["pack-release-ResultPattern.AspNet"],
            "group": "build",
            "problemMatcher": []
        }
    ]
}
